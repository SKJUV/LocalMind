# Configuration LMStudio
LM_STUDIO_URL=http://127.0.0.1:1234/v1
LM_STUDIO_API_KEY=lm-studio
LM_STUDIO_MODEL=

# Dossier de travail (par défaut: répertoire courant du projet)
PROJECT_PATH=

# Limites de sortie pour éviter les réponses trop longues
MAX_TOOL_OUTPUT_CHARS=3500
MAX_FILE_OUTPUT_CHARS=4000

# Réflexion / autonomie du modèle
LLM_TEMPERATURE=0.02
LLM_MAX_TOKENS=4096
LLM_MAX_ITERATIONS=25
LLM_THINKING_STEPS=3
LLM_TOOL_TIMEOUT_SECONDS=60
LLM_STRICT_FILE_TASKS=true
LLM_PLAN_THEN_ACTION=true
LLM_ENRICHED_TASK_MEMORY=true

# Profils recommandés selon la machine
# Faible:      LLM_TEMPERATURE=0.0  | LLM_MAX_TOKENS=1536 | LLM_MAX_ITERATIONS=12 | LLM_THINKING_STEPS=1 | LLM_TOOL_TIMEOUT_SECONDS=30
# Moyenne:     LLM_TEMPERATURE=0.02 | LLM_MAX_TOKENS=3072 | LLM_MAX_ITERATIONS=20 | LLM_THINKING_STEPS=2 | LLM_TOOL_TIMEOUT_SECONDS=45
# Puissante:   LLM_TEMPERATURE=0.02 | LLM_MAX_TOKENS=4096 | LLM_MAX_ITERATIONS=25 | LLM_THINKING_STEPS=3 | LLM_TOOL_TIMEOUT_SECONDS=60
# Ultra:       LLM_TEMPERATURE=0.02 | LLM_MAX_TOKENS=6144 | LLM_MAX_ITERATIONS=35 | LLM_THINKING_STEPS=4 | LLM_TOOL_TIMEOUT_SECONDS=90

# Objectif du projet
# Assistant local pour piloter des modèles d'IA en local et modifier le projet via outils contrôlés.
